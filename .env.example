# Pet App - Environment Variables Example
# Copy this file to .env.local, .env.staging, .env.production
# and update the values for each environment

# ============================================
# API Configuration
# ============================================
# API Gateway URL - routes to appropriate backend service
# Local dev: http://localhost:44300 (API Gateway)
# Staging: https://api-staging.petapp.com
# Production: https://api.petapp.com
EXPO_PUBLIC_API_URL=http://localhost:44300

# Request timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=30000

# ============================================
# App Configuration
# ============================================
# Environment name
EXPO_PUBLIC_ENVIRONMENT=development

# Log level (debug, info, warn, error)
EXPO_PUBLIC_LOG_LEVEL=debug

# Feature flags
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# ============================================
# Sentry Configuration (Error Tracking)
# ============================================
EXPO_PUBLIC_SENTRY_DSN=

# ============================================
# Dev/Testing
# ============================================
# Mock API responses (for development)
EXPO_PUBLIC_USE_MOCK_API=false
